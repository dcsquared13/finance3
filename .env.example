# ──────────────────────────────────────────────────────────────────────────────
# finance3 — Environment variable template
#
# Copy this file to .env and fill in your Alpaca paper trading credentials.
# NEVER commit .env to git (it is already in .gitignore).
#
# Get your keys at: https://app.alpaca.markets → Paper Trading → API Keys
# ──────────────────────────────────────────────────────────────────────────────

# Alpaca Paper Trading API credentials
APCA_API_KEY_ID=YOUR_ALPACA_PAPER_KEY_ID
APCA_API_SECRET_KEY=YOUR_ALPACA_PAPER_SECRET_KEY

# Leave this as-is for paper trading (change to https://api.alpaca.markets for live)
APCA_API_BASE_URL=https://paper-api.alpaca.markets
